<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OrangeHRM Automation Suite" parallel="methods" thread-count="3" verbose="1">

    <parameter name="browser" value="chrome"/>

    <test name="Smoke - Login + Dashboard">
        <classes>
            <class name="com.orangehrm.tests.LoginTest"/>
        </classes>
    </test>

    <test name="PIM - Tables and Pagination">
        <classes>
            <class name="com.orangehrm.tests.PIMTest"/>
        </classes>
    </test>

    <test name="Admin - Dropdowns">
        <classes>
            <class name="com.orangehrm.tests.AdminTest"/>
        </classes>
    </test>

    <test name="Hybrid">
        <classes>
            <class name="com.orangehrm.tests.HybridTest"/>
        </classes>
    </test>

    <test name="Keyword Driven">
        <classes>
            <class name="com.orangehrm.tests.KeywordDrivenTest"/>
        </classes>
    </test>

    <test name="Parallel Threads">
        <classes>
            <class name="com.orangehrm.tests.ParallelLoginTest"/>
        </classes>
    </test>

    <test name="iFrame and ShadowDOM">
        <classes>
            <class name="com.orangehrm.tests.IFrameTest"/>
            <class name="com.orangehrm.tests.ShadowDOMTest"/>
        </classes>
    </test>
</suite>
